{
  "name": "@hivertc/react",
  "version": "1.0.0",
  "description": "React bindings for HiveRTC SDK — hooks and pre-built components for video meetings",
  "author": "Tanmay Chaurasia",
  "repository": {
    "type": "git",
    "url": "https://github.com/TanmayChaurasia24/HiveRTC"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch"
  },
  "dependencies": {
    "@hivertc/sdk": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "socket.io-client": "^4.0.0",
    "mediasoup-client": "^3.0.0"
  },
  "devDependencies": {
    "react": "^19.1.0",
    "@types/react": "^19.1.0",
    "socket.io-client": "^4.8.1",
    "mediasoup-client": "^3.7.22",
    "typescript": "^5.9.0"
  },
  "license": "MIT"
}
